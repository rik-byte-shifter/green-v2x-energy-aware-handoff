    rssi_epb = [r["rssi_stats"]["avg_energy_per_bit"] for r in results_list]

    # Paired tests: same seeds → paired t-tests (RSSI vs energy-aware)
    t_j, p_j = stats.ttest_rel(rssi_e, ea_e, alternative="greater", nan_policy="omit")
